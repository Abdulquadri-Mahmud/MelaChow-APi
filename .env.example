# Server
PORT=10000
NODE_ENV=production

# Database
MONGO_URI=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Admin
ADMIN_EMAIL=

# Email (Nodemailer)
EMAIL_USER=
EMAIL_PASS=

# Frontend URL (CORS + Socket.IO)
CLIENT_URL=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Payment Callbacks
# Update these to production URLs before deploying
CALL_BACK_URL=
FUND_WALLET_CALL_BACK_URL=

# Webhook
# Update to Render URL after deployment:
# https://your-app-name.onrender.com/api/orders/webhook
webhook=

# Web Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=
