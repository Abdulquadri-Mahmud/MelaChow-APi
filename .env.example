# Server
PORT=10000
NODE_ENV=production

# Database
MONGO_URI=
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/melachow?schema=public"
# Keep Mongo as default while migrating domain-by-domain.
# Set to "postgres" locally after Prisma is installed/migrated to test migrated read paths.
DB_READ_PROVIDER=mongo
# Menu/catalog stays behind its own switch until vendor/menu data import is complete.
DB_MENU_READ_PROVIDER=mongo
# Search reads stay separate so menu search can be tested without moving trend analytics.
DB_SEARCH_READ_PROVIDER=mongo
# Foods-by-location reads stay separate because the route is authenticated and location-heavy.
DB_FOODS_BY_LOCATION_READ_PROVIDER=mongo
# Recommendations stay separate because order-history-backed trending needs its own cutover checks.
DB_RECOMMENDATION_READ_PROVIDER=mongo
# Public review reads stay separate from review writes and admin/user review management.
DB_PUBLIC_REVIEW_READ_PROVIDER=mongo
# Private/admin review reads stay separate from review writes and deletes.
DB_REVIEW_READ_PROVIDER=mongo
# Category metrics stay separate from broader admin analytics while orders/users are still moving.
DB_CATEGORY_METRICS_READ_PROVIDER=mongo
# User signup metrics stay separate while user import completeness is verified.
DB_USER_METRICS_READ_PROVIDER=mongo
# Vendor sales/registration metrics stay separate because they depend on order import completeness.
DB_VENDOR_METRICS_READ_PROVIDER=mongo
# Vendor order dashboard reads stay separate from order status mutation/write paths.
DB_VENDOR_ORDER_READ_PROVIDER=mongo
# Admin order list/detail/stats reads stay separate from status override and logistics writes.
DB_ADMIN_ORDER_READ_PROVIDER=mongo
# Admin rider and rider-assignment reads stay separate from logistics write paths.
DB_ADMIN_RIDER_READ_PROVIDER=mongo
# Platform config reads stay separate from config writes.
DB_PLATFORM_CONFIG_READ_PROVIDER=mongo
# Rider dashboard reads stay separate from rider status/order mutation paths.
DB_RIDER_READ_PROVIDER=mongo
# Wallet, bank-account, and withdrawal reads stay separate from payment/withdrawal writes.
DB_WALLET_READ_PROVIDER=mongo
DB_ADMIN_FINANCE_READ_PROVIDER=mongo
# Cart reads/writes stay separate from order creation and payment writes.
DB_CART_READ_PROVIDER=mongo
DB_CART_WRITE_PROVIDER=mongo
DB_ORDER_WRITE_PROVIDER=mongo
DB_PAYMENT_WRITE_PROVIDER=mongo
DB_ORDER_STATUS_WRITE_PROVIDER=mongo
DB_RIDER_ASSIGNMENT_WRITE_PROVIDER=mongo

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Admin
ADMIN_EMAIL=

# Email (Nodemailer)
EMAIL_USER=
EMAIL_PASS=

# Frontend URL (CORS + Socket.IO)
CLIENT_URL=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Payment Callbacks
# Update these to production URLs before deploying
CALL_BACK_URL=
FUND_WALLET_CALL_BACK_URL=

# Webhook
# Update to Render URL after deployment:
# https://your-app-name.onrender.com/api/orders/webhook
webhook=

# Web Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=
