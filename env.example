# --- SERVER CONFIGURATION ---
PORT=3001
MONGO_URI=your_mongodb_uri
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# --- EMAIL CONFIGURATION ---
EMAIL_USER=admin@grubdash.com
EMAIL_PASS=your_email_password
ADMIN_EMAIL=admin@grubdash.com

# --- EXTERNAL SERVICES ---
CLIENT_URL=http://localhost:3000
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_SERVICE_SID=...

# --- WEB PUSH NOTIFICATIONS ---
# Generate these using: node scripts/generate-vapid-keys.js
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@grubdash.com
