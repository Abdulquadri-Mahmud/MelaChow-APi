model RiderAssignment {
  id            String    @id @default(uuid()) @db.Uuid
  legacyMongoId String?   @unique @map("legacy_mongo_id")
  orderId       String    @map("order_id") @db.Uuid
  vendorOrderId String?   @map("vendor_order_id") @db.Uuid
  riderId       String?   @map("rider_id") @db.Uuid
  vendorId      String?   @map("vendor_id") @db.Uuid
  cityId        String?   @map("city_id") @db.Uuid
  stateId       String?   @map("state_id") @db.Uuid
  status        RiderAssignmentStatus @default(pending)
  reason        String?
  expiresAt     DateTime? @map("expires_at")
  respondedAt   DateTime? @map("responded_at")
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendorOrder VendorOrder? @relation(fields: [vendorOrderId], references: [id], onDelete: SetNull)
  rider Rider? @relation(fields: [riderId], references: [id], onDelete: SetNull)
  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  city City? @relation(fields: [cityId], references: [id], onDelete: SetNull)
  state State? @relation(fields: [stateId], references: [id], onDelete: SetNull)

  @@index([orderId, status, createdAt])
  @@index([riderId, status, createdAt])
  @@index([expiresAt])
  @@map("rider_assignments")
}

