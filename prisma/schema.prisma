generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountRole {
  user
  vendor
  rider
  admin
}

enum AdminRole {
  admin
  super_admin @map("super-admin")
  finance_admin @map("finance-admin")
}

enum LocationStatus {
  approved
  pending_review
}

enum DeliveryManagedBy {
  vendor
  admin
}

enum RiderStatus {
  available
  pending_assignment
  on_delivery
  offline
}

enum VehicleOwnership {
  own
  platform
}

enum VehicleType {
  bicycle
  motorbike
}

enum VehicleStatus {
  available
  assigned
  maintenance
  inactive
}

enum DietaryType {
  veg
  non_veg @map("non-veg")
  vegan
  halal
  kosher
  mixed
}

enum ItemType {
  FOOD
  DRINK
  SIDE
  PROTEIN
  SWALLOW
  SOUP
  DESSERT
  OTHER
  combo
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
  EXPIRED
}

enum CartLineItemType {
  PORTION_ITEM
  VARIANT_ITEM
}

enum CartItemStatusAtAdd {
  AVAILABLE
  SOLD_OUT
  UNAVAILABLE
}

enum OrderItemType {
  item
  combo
}

enum OrderStatus {
  pending
  accepted
  preparing
  ready_for_pickup
  rider_assigned
  out_for_delivery
  delivered
  completed
  cancelled
  failed
  refunded
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum PaymentAttemptStatus {
  initialized
  pending
  success
  failed
  amount_mismatch
  currency_mismatch
  provider_mismatch
  recovered
  review
  abandoned
}

enum PaymentRecoveryState {
  awaiting_verification
  recovered
  failed
  review
}

enum WalletOwnerModel {
  Admin
  Vendor
  User
  Rider
}

enum WalletTransactionDirection {
  credit
  debit
}

enum WalletTransactionType {
  commission
  escrow_hold
  escrow_release
  delivery_fee
  rider_payout
  delivery_spread
  service_fee
  refund
  order_payment
  top_up
  manual_credit
  manual_debit
  withdrawal
}

enum WithdrawalStatus {
  pending
  processing
  completed
  failed
  reversed
}

enum NotificationRole {
  user
  vendor
  admin
  rider
}

enum NotificationType {
  order_placed
  order_confirmed
  order_preparing
  order_ready
  order_dispatched
  order_delivered
  order_cancelled
  order_assigned
  rider_order_rejected
  vendor_new_order
  vendor_order_cancelled
  vendor_rider_assigned
  admin_order_ready
  admin_order_delivered
  rider_assignment_needed
  rider_assignment_accepted
  rider_assignment_timeout
  vendor_review
  support_ticket
  system
  promo
  discount
  delivery_nearby
  account_update
  general
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum DiscountScope {
  GLOBAL_ORDER
  VENDOR_ORDER
  SPECIFIC_ITEMS
  DELIVERY_FEE
}

enum PromoFundedBy {
  PLATFORM
  VENDOR
}

enum RiderAssignmentStatus {
  pending
  accepted
  rejected
  timeout
  picked_up
  delivered
}

enum SupportTicketStatus {
  open
  pending
  resolved
  closed
}

enum ReportStatus {
  pending
  reviewed
  resolved
  dismissed
}

enum RefundStatus {
  pending
  processing
  completed
  failed
}

model State {
  id            String   @id @default(uuid()) @db.Uuid
  legacyMongoId String?  @unique @map("legacy_mongo_id")
  name          String   @unique
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  cities City[]
  vendors Vendor[]
  riders Rider[]
  userAddresses UserAddress[]
  riderAssignments RiderAssignment[]

  @@index([name, isActive])
  @@map("states")
}

model City {
  id                  String   @id @default(uuid()) @db.Uuid
  legacyMongoId       String?  @unique @map("legacy_mongo_id")
  name                String
  stateId             String   @map("state_id") @db.Uuid
  isActive            Boolean  @default(true) @map("is_active")
  platformDeliveryFee Int      @default(0) @map("platform_delivery_fee_kobo")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  state State @relation(fields: [stateId], references: [id], onDelete: Restrict)
  vendors Vendor[]
  riders Rider[]
  userAddresses UserAddress[]
  riderAssignments RiderAssignment[]
  searchTrends SearchTrend[]

  @@unique([name, stateId])
  @@index([stateId, isActive])
  @@map("cities")
}

model Category {
  id            String     @id @default(uuid()) @db.Uuid
  legacyMongoId String?    @unique @map("legacy_mongo_id")
  name          String
  slug          String
  parentId      String?    @map("parent_id") @db.Uuid
  description   String     @default("")
  image         String     @default("")
  isActive      Boolean    @default(true) @map("is_active")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryTree")
  menuItems MenuItem[]
  comboItems ComboItem[]

  @@index([parentId])
  @@index([slug, parentId])
  @@map("categories")
}

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  legacyMongoId        String?   @unique @map("legacy_mongo_id")
  firstname            String?
  lastname             String?
  fullName             String?   @map("full_name")
  email                String    @unique
  password             String?
  phone                String?
  avatar               String?
  walletBalance        Int       @default(0) @map("wallet_balance_kobo")
  totalOrders          Int       @default(0) @map("total_orders")
  isVerified           Boolean   @default(false) @map("is_verified")
  isActive             Boolean   @default(true) @map("is_active")
  lastLogin            DateTime? @map("last_login")
  resetPasswordToken   String?   @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")
  loginAttempts        Int       @default(0) @map("login_attempts")
  lockUntil            DateTime? @map("lock_until")
  suspended            Boolean   @default(false)
  banned               Boolean   @default(false)
  suspensionReason     String?   @map("suspension_reason")
  banReason            String?   @map("ban_reason")
  activityLog          Json      @default("[]") @map("activity_log")
  role                 AccountRole @default(user)
  otp                  String?
  otpExpires           DateTime? @map("otp_expires")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  addresses UserAddress[]
  carts Cart[]
  orders Order[]
  paymentAttempts PaymentAttempt[]
  refunds Refund[]
  transactions Transaction[]
  invoices Invoice[]
  reviews Review[]
  reports Report[]
  supportTickets SupportTicket[]
  discountUsages DiscountUsage[]
  notifications Notification[]
  freeDeliveryClaims FreeDeliveryClaim[]
  vendorDeliveryClaims VendorDeliveryClaim[]
  searchTrends SearchTrend[]

  @@index([email])
  @@index([phone])
  @@index([isActive])
  @@map("users")
}

model UserAddress {
  id            String   @id @default(uuid()) @db.Uuid
  legacyMongoId String?  @unique @map("legacy_mongo_id")
  userId        String   @map("user_id") @db.Uuid
  label         String   @default("Home")
  addressLine   String   @map("address_line")
  cityText      String?  @map("city")
  stateText     String?  @map("state")
  cityId        String?  @map("city_id") @db.Uuid
  stateId       String?  @map("state_id") @db.Uuid
  cityName      String?  @map("city_name")
  stateName     String?  @map("state_name")
  postalCode    String?  @map("postal_code")
  latitude      Float?
  longitude     Float?
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  city City? @relation(fields: [cityId], references: [id], onDelete: SetNull)
  state State? @relation(fields: [stateId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([cityId])
  @@index([stateId])
  @@map("user_addresses")
}

model Admin {
  id                   String    @id @default(uuid()) @db.Uuid
  legacyMongoId        String?   @unique @map("legacy_mongo_id")
  name                 String
  email                String    @unique
  password             String
  role                 AdminRole @default(admin)
  resetPasswordToken   String?   @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")
  loginAttempts        Int       @default(0) @map("login_attempts")
  lockUntil            DateTime? @map("lock_until")
  lastLogin            DateTime? @map("last_login")
  otp                  String?
  otpExpires           DateTime? @map("otp_expires")
  walletId             String?   @map("wallet_id") @db.Uuid
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  notifications Notification[]
  platformConfigs PlatformConfig[]

  @@index([email])
  @@index([role])
  @@map("admins")
}

model Vendor {
  id                       String    @id @default(uuid()) @db.Uuid
  legacyMongoId            String?   @unique @map("legacy_mongo_id")
  name                     String
  email                    String
  phone                    String
  password                 String?
  resetPasswordToken       String?   @map("reset_password_token")
  resetPasswordExpires     DateTime? @map("reset_password_expires")
  loginAttempts            Int       @default(0) @map("login_attempts")
  lockUntil                DateTime? @map("lock_until")
  lastLogin                DateTime? @map("last_login")
  otp                      String?
  otpExpires               DateTime? @map("otp_expires")
  storeName                String    @map("store_name")
  storeSlug                String?   @unique @map("store_slug")
  storeDescription         String    @default("") @map("store_description")
  logo                     String    @default("")
  coverImage               String    @default("") @map("cover_image")
  address                  Json      @default("{}")
  stateId                  String?   @map("state_id") @db.Uuid
  cityId                   String?   @map("city_id") @db.Uuid
  locationStatus           LocationStatus? @map("location_status")
  requestedState           String    @default("") @map("requested_state")
  requestedCity            String    @default("") @map("requested_city")
  cuisineTypes             String[]  @default([]) @map("cuisine_types")
  openingHours             Json      @default("{}") @map("opening_hours")
  walletId                 String?   @map("wallet_id") @db.Uuid
  payoutDetails            Json?     @map("payout_details")
  totalSales               Int       @default(0) @map("total_sales_kobo")
  totalOrders              Int       @default(0) @map("total_orders")
  commissionRate           Float     @default(0.1) @map("commission_rate")
  rating                   Float     @default(0)
  ratingCount              Int       @default(0) @map("rating_count")
  verified                 Boolean   @default(false)
  isApproved               Boolean   @default(false) @map("is_approved")
  termsAcceptance          Json      @default("{}") @map("terms_acceptance")
  suspended                Boolean   @default(false)
  active                   Boolean   @default(true)
  hasActiveDeliveryPromo   Boolean   @default(false) @map("has_active_delivery_promo")
  suspensionReason         String    @default("") @map("suspension_reason")
  acceptsDelivery          Boolean   @default(true) @map("accepts_delivery")
  flatRateDeliveryFee      Int       @default(0) @map("flat_rate_delivery_fee_kobo")
  deliveryRadiusKm         Float     @default(5) @map("delivery_radius_km")
  tags                     String[]  @default([])
  metadata                 Json      @default("{}")
  ownerIds                 String[]  @default([]) @map("owner_ids")
  deletedAt                DateTime? @map("deleted_at")
  adminNotes               String    @default("") @map("admin_notes")
  deliveryManagedBy        DeliveryManagedBy @default(admin) @map("delivery_managed_by")
  platformDeliveryFeeOverride Int?   @map("platform_delivery_fee_override_kobo")
  role                     AccountRole @default(vendor)
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  state State? @relation(fields: [stateId], references: [id], onDelete: SetNull)
  city City? @relation(fields: [cityId], references: [id], onDelete: SetNull)
  menuSections VendorMenuSection[]
  menuItems MenuItem[]
  legacyFoods Food[]
  comboItems ComboItem[]
  subCarts VendorSubCart[]
  vendorOrders VendorOrder[]
  orderItems OrderItem[]
  vendorDeliveryFees VendorDeliveryFee[]
  riders Rider[]
  reviews Review[]
  withdrawals Withdrawal[]
  transactions Transaction[]
  notifications Notification[]
  discounts Discount[]
  vendorDeliveryPromos VendorDeliveryPromo[]
  vendorDeliveryClaims VendorDeliveryClaim[]
  riderAssignments RiderAssignment[]
  searchTrends SearchTrend[]

  @@index([email])
  @@index([phone])
  @@index([storeName])
  @@index([stateId])
  @@index([cityId])
  @@index([locationStatus])
  @@index([verified])
  @@index([isApproved])
  @@index([active, suspended])
  @@index([hasActiveDeliveryPromo])
  @@map("vendors")
}

model Rider {
  id                   String    @id @default(uuid()) @db.Uuid
  legacyMongoId        String?   @unique @map("legacy_mongo_id")
  name                 String
  phone                String
  email                String?
  avatar               String    @default("")
  vendorId             String?   @map("vendor_id") @db.Uuid
  stateId              String?   @map("state_id") @db.Uuid
  cityId               String?   @map("city_id") @db.Uuid
  locationStatus       LocationStatus? @map("location_status")
  requestedState       String    @default("") @map("requested_state")
  requestedCity        String    @default("") @map("requested_city")
  serviceZones         String[]  @default([]) @map("service_zones")
  vehicleOwnership     VehicleOwnership @default(own) @map("vehicle_ownership")
  vehicleType          VehicleType @default(bicycle) @map("vehicle_type")
  platformVehicleId    String?   @map("platform_vehicle_id") @db.Uuid
  managedBy            DeliveryManagedBy @default(vendor) @map("managed_by")
  password             String?
  otp                  String?
  otpExpires           DateTime? @map("otp_expires")
  resetPasswordToken   String?   @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")
  loginAttempts        Int       @default(0) @map("login_attempts")
  lockUntil            DateTime? @map("lock_until")
  lastLogin            DateTime? @map("last_login")
  status               RiderStatus @default(offline)
  currentOrderId       String?   @map("current_order_id") @db.Uuid
  assignmentExpiresAt  DateTime? @map("assignment_expires_at")
  approvedAt           DateTime? @map("approved_at")
  approvedBy           String?   @map("approved_by") @db.Uuid
  isActive             Boolean   @default(true) @map("is_active")
  isVerified           Boolean   @default(false) @map("is_verified")
  deletedAt            DateTime? @map("deleted_at")
  totalDeliveries      Int       @default(0) @map("total_deliveries")
  totalEarnings        Int       @default(0) @map("total_earnings")
  rating               Float     @default(0)
  ratingCount          Int       @default(0) @map("rating_count")
  notes                String?
  metadata             Json      @default("{}")
  payoutDetails        Json      @default("{}") @map("payout_details")
  role                 AccountRole @default(rider)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  state State? @relation(fields: [stateId], references: [id], onDelete: SetNull)
  city City? @relation(fields: [cityId], references: [id], onDelete: SetNull)
  platformVehicle PlatformVehicle? @relation(fields: [platformVehicleId], references: [id], onDelete: SetNull)
  orders Order[]
  vendorOrders VendorOrder[]
  riderWithdrawals RiderWithdrawal[]
  notifications Notification[]
  riderAssignments RiderAssignment[]

  @@index([phone])
  @@index([email])
  @@index([vendorId, status])
  @@index([vendorId, isActive, deletedAt])
  @@index([cityId, status, isActive, isVerified])
  @@index([platformVehicleId])
  @@index([assignmentExpiresAt])
  @@map("riders")
}

model PlatformVehicle {
  id            String   @id @default(uuid()) @db.Uuid
  legacyMongoId String?  @unique @map("legacy_mongo_id")
  label         String
  identifier    String?  @unique
  vehicleType   VehicleType @default(bicycle) @map("vehicle_type")
  status        VehicleStatus @default(available)
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  riders Rider[]

  @@index([status])
  @@map("platform_vehicles")
}

model VendorMenuSection {
  id            String    @id @default(uuid()) @db.Uuid
  legacyMongoId String?   @unique @map("legacy_mongo_id")
  vendorId      String    @map("vendor_id") @db.Uuid
  name          String
  description   String?
  sortOrder     Int       @default(0) @map("sort_order")
  isVisible     Boolean   @default(true) @map("is_visible")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]
  comboItems ComboItem[]

  @@index([vendorId, isVisible, sortOrder, deletedAt])
  @@map("vendor_menu_sections")
}

model MenuItem {
  id                 String   @id @default(uuid()) @db.Uuid
  legacyMongoId      String?  @unique @map("legacy_mongo_id")
  vendorId           String   @map("vendor_id") @db.Uuid
  platformCategoryId String   @map("platform_category_id") @db.Uuid
  vendorSectionId    String?  @map("vendor_section_id") @db.Uuid
  name               String
  description        String?
  imageUrl           String?  @map("image_url")
  itemType           ItemType @default(FOOD) @map("item_type")
  dietaryType        DietaryType @default(mixed) @map("dietary_type")
  isAvailable        Boolean  @default(true) @map("is_available")
  isInStock          Boolean  @default(true) @map("is_in_stock")
  isArchived         Boolean  @default(false) @map("is_archived")
  categoryDeactivated Boolean @default(false) @map("category_deactivated")
  sortOrder          Int      @default(0) @map("sort_order")
  prepTimeMinutes    Int?     @map("prep_time_minutes")
  tags               String[] @default([])
  rating             Float    @default(0)
  ratingCount        Int      @default(0) @map("rating_count")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  platformCategory Category @relation(fields: [platformCategoryId], references: [id], onDelete: Restrict)
  vendorSection VendorMenuSection? @relation(fields: [vendorSectionId], references: [id], onDelete: SetNull)
  portions MenuItemPortion[]
  choiceGroups MenuItemChoiceGroup[]
  cartLineItems CartLineItem[]
  orderItems OrderItem[]
  reviews Review[]

  @@index([vendorId, isArchived, isAvailable, isInStock])
  @@index([platformCategoryId, isArchived, isAvailable, isInStock])
  @@index([vendorId, vendorSectionId])
  @@index([vendorId, platformCategoryId])
  @@map("menu_items")
}

model MenuItemPortion {
  id            String   @id @default(uuid()) @db.Uuid
  legacyMongoId String?  @unique @map("legacy_mongo_id")
  menuItemId    String   @map("menu_item_id") @db.Uuid
  label         String
  price         Int      @map("price_kobo")
  isDefault     Boolean  @default(false) @map("is_default")
  isAvailable   Boolean  @default(true) @map("is_available")
  isInStock     Boolean  @default(true) @map("is_in_stock")
  maxQuantity   Int?     @map("max_quantity")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  cartLineItems CartLineItem[]
  orderItems OrderItem[]

  @@index([menuItemId, isAvailable, isInStock])
  @@index([menuItemId, isDefault])
  @@map("menu_item_portions")
}

model MenuItemChoiceGroup {
  id            String   @id @default(uuid()) @db.Uuid
  legacyMongoId String?  @unique @map("legacy_mongo_id")
  menuItemId    String   @map("menu_item_id") @db.Uuid
  name          String
  imageUrl      String?  @map("image_url")
  minSelections Int      @default(0) @map("min_selections")
  maxSelections Int      @default(1) @map("max_selections")
  isRequired    Boolean  @default(false) @map("is_required")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options MenuItemChoiceOption[]

  @@index([menuItemId])
  @@map("menu_item_choice_groups")
}

model MenuItemChoiceOption {
  id            String   @id @default(uuid()) @db.Uuid
  legacyMongoId String?  @unique @map("legacy_mongo_id")
  groupId       String   @map("group_id") @db.Uuid
  label         String
  imageUrl      String?  @map("image_url")
  priceModifier Int      @default(0) @map("price_modifier")
  isAvailable   Boolean  @default(true) @map("is_available")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  group MenuItemChoiceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("menu_item_choice_options")
}

model ComboItem {
  id                 String   @id @default(uuid()) @db.Uuid
  legacyMongoId      String?  @unique @map("legacy_mongo_id")
  vendorId           String   @map("vendor_id") @db.Uuid
  platformCategoryId String   @map("platform_category_id") @db.Uuid
  vendorSectionId    String?  @map("vendor_section_id") @db.Uuid
  name               String
  description        String?
  imageUrl           String?  @map("image_url")
  price              Int      @map("price_kobo")
  dietaryType        DietaryType @default(mixed) @map("dietary_type")
  prepTimeMinutes    Int?     @map("prep_time_minutes")
  tags               String[] @default([])
  contents           String[] @default([])
  choiceGroups       Json     @default("[]") @map("choice_groups")
  isAvailable        Boolean  @default(true) @map("is_available")
  isInStock          Boolean  @default(true) @map("is_in_stock")
  isArchived         Boolean  @default(false) @map("is_archived")
  sortOrder          Int      @default(0) @map("sort_order")
  rating             Float    @default(0)
  ratingCount        Int      @default(0) @map("rating_count")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  platformCategory Category @relation(fields: [platformCategoryId], references: [id], onDelete: Restrict)
  vendorSection VendorMenuSection? @relation(fields: [vendorSectionId], references: [id], onDelete: SetNull)
  cartLineItems CartLineItem[]
  orderItems OrderItem[]

  @@index([vendorId, isArchived, isAvailable])
  @@index([platformCategoryId, isArchived])
  @@index([vendorId, vendorSectionId])
  @@map("combo_items")
}

model Cart {
  id            String   @id @default(uuid()) @db.Uuid
  legacyMongoId String?  @unique @map("legacy_mongo_id")
